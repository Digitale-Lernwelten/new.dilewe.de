---
import AboutUsHeaderCard from './AboutUsHeaderCard'
import type { AboutUsHeaderSection } from './MobileAboutUsHeader'

interface Props {
	image?: ImageMetadata;
	alt?: string;
	odd?: boolean;
	sections: AboutUsHeaderSection[];
}

const {image, alt, odd, sections} = Astro.props;

---

<AboutUsHeaderCard image={image} alt={alt} odd={odd ? true : false} sections={sections} client:only="react" />