---
interface Props {
	images: ImageMetadata[];
	imageAlt?: string;
	fox?: boolean;
	gradient?: boolean;
}

import imageFox from "../assets/header-fox.png";
import { ImageShow } from "./ImageShow";
const { images, imageAlt, fox, gradient } = Astro.props;
---

<div class="outerWrap">
	<div class="wrap">
		<!-- <svg height="0" width="0">
			<defs>
				<clipPath id="headerImageClipPath" clipPathUnits="objectBoundingBox">
					<path d="M 1 0 L 0 0 C 0.05 0.4 0.05 0.6 0 1 L 1 1 L 1 0"></path>
				</clipPath>
				<clipPath id="headerImageClipPathTop" clipPathUnits="objectBoundingBox">
					<path d="M 1 0.2 C 0.6667 -0.05 0.3333 -0.05 0 0.2 L 0 0.8 C 0.3333 1.05 0.6667 1.05 1 0.8 L 1 0.2"></path>
				</clipPath>
			</defs>
		</svg> -->

		<div class="image">
			<ImageShow images={images} imageAlt={imageAlt} client:load />
			<div class={`headerWrap${gradient ? " gradientLeftToRight" : ""}`}>
				<div class="text">
					<slot />
				</div>
			</div>
		</div>
	</div>
	{ !fox ? '' : (<img class="fox" src={imageFox.src} width={imageFox.width} height={imageFox.height} alt="Ein Fuchs" />)}
</div>

<style>
	.wrap {
		width: 100%;
		height: 100%;
		position: relative;
		background: var(--nav-background);
		overflow: hidden;
	}

	.outerWrap {
		width: 100%;
		height: calc(min(50vh, 40vw));
		min-height: 240px;
		position: relative;
	}

	.image {
		width: 100%;
		height: 100%;
		display: flex;
		position: absolute;
		right: 0;
		top: 0;
		clip-path: url(#headerImageClipPath);
	}

	.headerWrap {
		display: flex;
		position: absolute;
		justify-content: center;
		align-items: center;
		flex: 1;
		width: 100%;
		height: 100%;
	}
	.gradientLeftToRight {
		background: linear-gradient(270deg, rgba(30, 30, 30, 0.00) 0%, rgba(0, 0, 0, 0.80) 65%);
	}
	.text {
		display: flex;
		flex: 1;
		position: relative;
		justify-content: center;
		align-items: center;
		color: white;
		height: 100%;
	}

	.fox {
		position: absolute;
		z-index: 2;
		right: 50%;
		margin-right: -760px;
		width: 180px;
		height: auto;
		display: block;
		bottom: 0;
		z-index:10;
		transform: translate(0, 45.5%);
	}

@media only screen and (max-width: 750px)  {
		.text,
		.image {
			width: 100%;
			height: calc(min(50vh, 40vw));
			position: relative;
		}

		.image {
			margin-top: calc(min(-2vh, -2vw));
			height: calc(min(70vh, 70vw));
			z-index:10;
		}

		.outerWrap {
			height: auto;
		}

		.outerWrap::after {
			content:'';
			display: block;
			position: absolute;
			bottom: 0;
			left: 0;
			width:100%;
			background: #fff;
			height: calc(min(20vh, 20vw));
		}
		.gradientLeftToRight {
			background: linear-gradient(0deg, rgba(30, 30, 30, 0.00) 0%, rgba(0, 0, 0, 0.80) 80%);
		}

	}

	@media only screen and (max-width: 1750px)  {
		.fox {
			display: none;
		}
	}
</style>
