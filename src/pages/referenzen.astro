<script>
	document.addEventListener('click', (e) => {
		const trigger = (e.target as HTMLElement).closest('.ref-dropdown-trigger');
		if (trigger) {
			e.stopPropagation();
			const dropdown = trigger.closest('.ref-dropdown');
			if (!dropdown) return;
			const wasOpen = dropdown.classList.contains('open');
			document.querySelectorAll('.ref-dropdown.open').forEach(d => d.classList.remove('open'));
			if (!wasOpen) dropdown.classList.add('open');
			return;
		}
		if (!(e.target as HTMLElement).closest('.ref-dropdown-menu')) {
			document.querySelectorAll('.ref-dropdown.open').forEach(d => d.classList.remove('open'));
		}
	});
</script>
