---
import Layout from "../layouts/Layout.astro";
import flo from "../assets/aboutus/flo.png";
import { createPersonSchema } from "../lib/schema";

const description = "Lebenslauf und Publikationen von Dr. Florian Sochatzy, Geschäftsführer der Digitalen Lernwelten GmbH.";
const florianSchema = createPersonSchema({
	name: "Florian Sochatzy",
	pathname: "/florian-sochatzy-vita/",
	description,
	honorificPrefix: "Dr.",
	jobTitle: "Geschäftsführer",
	image: new URL(flo.src, Astro.site ?? "https://dilewe.de").toString(),
	knowsAbout: ["Digitale Bildung", "Digitale Schulbücher", "Bildungsmedien"],
});
---

<Layout
	title="Dr. Florian Sochatzy – Lebenslauf und Publikationen"
	bodyClass="index"
	description={description}
	pageType="ProfilePage"
	schema={florianSchema}
	mainEntity={{ '@id': florianSchema['@id'] }}
>
	<div class="vita-detail">

		<h1>Dr. Florian Sochatzy</h1>
		<p class="subtitle">Lebenslauf und Publikationen</p>
		<div class="intro-with-image">
			<img src={flo.src} alt="Dr. Florian Sochatzy" class="portrait" />
			<p>Dr. Florian Sochatzy ist Unternehmer, Autor und Destillateur. In diesen unterschiedlichen Feldern treiben ihn ähnliche Fragen an: Wie kann man Prozesse für alle Beteiligten sinn- und freudvoll gestalten? Warum wird etwas so und nicht anders gemacht? Wer ist eigentlich für den gegenwärtigen Zustand verantwortlich? Was müsste man tun, um den Status quo zu überwinden? Welche Vorteile und neuen Möglichkeiten können dadurch entstehen? Diese Fragen erörtert er unter anderem auf der EduCouch, dem Podcast-Format der Digitalen Lernwelten.</p>
		</div>

