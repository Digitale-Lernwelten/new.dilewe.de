		background: #f7f7f7;
		border-radius: 6px;
		padding: 1.5rem 2rem;
		margin-bottom: 2.5rem;
	}

	.meta dl {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.5rem 1.5rem;
		margin: 0;
	}

	.meta dt {
		font-weight: 600;
		font-size: 0.85rem;
		color: #333;
		text-transform: uppercase;
		letter-spacing: 0.03em;
	}

	.meta dd {
		margin: 0;
		font-size: 0.95rem;
		color: #555;
	}

	.meta dd a {
