		font-size: 1.1rem;
		font-weight: 500;
		color: #333;
		margin: 1.5rem 0 0.5rem;
	}

	p {
		font-size: 1rem;
		color: #555;
		line-height: 1.8;
		margin: 0 0 1rem;
	}

	@media (max-width: 600px) {
		.meta dl {
			grid-template-columns: 1fr;
		}
		.meta dt {
			margin-top: 0.5rem;
		}
	}
</style>
