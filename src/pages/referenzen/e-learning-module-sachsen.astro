		border-radius: 6px;
		padding: 1.5rem 2rem;
		margin-bottom: 2.5rem;
	}

	.meta dl {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.5rem 1.5rem;
		margin: 0;
	}

	.meta dt {
		font-weight: 600;
		font-size: 0.85rem;
		color: #333;
		text-transform: uppercase;
		letter-spacing: 0.03em;
	}

	.meta dd {
		margin: 0;
		font-size: 0.95rem;
		color: #555;
	}

	.meta dd a {
		color: var(--tertiary, #027AAD);
		text-decoration: none;
	}

	.meta dd a:hover {
		text-decoration: underline;
	}

	blockquote {
		border-left: 3px solid var(--primary, #027AAD);
		margin: 0 0 2.5rem;
		padding: 1rem 1.5rem;
		background: rgba(2, 122, 173, 0.04);
		border-radius: 0 4px 4px 0;
	}

	blockquote p {
		font-size: 1.05rem;
		font-style: italic;
		color: #333;
		line-height: 1.7;
		margin: 0 0 0.5rem;
	}

	blockquote cite {
		font-size: 0.85rem;
		color: #888;
		font-style: normal;
	}

	h2 {
		font-size: 1.3rem;
		font-weight: 500;
		color: var(--primary);
		margin: 2.5rem 0 0.75rem;
	}

	h3 {
		font-size: 1.1rem;
		font-weight: 500;
		color: #333;
		margin: 1.5rem 0 0.5rem;
	}

	p {
		font-size: 1rem;
		color: #555;
		line-height: 1.8;
		margin: 0 0 1rem;
	}

	@media (max-width: 600px) {
		.meta dl {
			grid-template-columns: 1fr;
		}
		.meta dt {
			margin-top: 0.5rem;
		}
	}
</style>
