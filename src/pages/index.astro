---
import Layout from "../layouts/Layout.astro";
import HeaderImage from "../components/HeaderImage.astro";
import { Logo }  from "../components/Logo";
import { headerImages } from "../assets/header";
import { HeaderText } from "../components/HeaderText"
import marcus from "../assets/aboutus/marcus.png"
import flo from "../assets/aboutus/flo.png"
import obi from "../assets/aboutus/obi.png"
import kevin from "../assets/aboutus/kevin.png"
import fabi from "../assets/aboutus/fabi.png"
import paula from "../assets/aboutus/paula.png"
import carla from "../assets/aboutus/carla.png"
import chris from "../assets/aboutus/chris.png"
import felix from "../assets/aboutus/felix.png"
import asti from "../assets/aboutus/asti.png"
import AboutUsHeaderCard from "../components/AboutUsHeaderCardWrap.astro"
import { MobileHeaderText } from "../components/MobileHeaderText"
import { AboutUsGalleryCard } from "../components/AboutUsGalleryCard"
import { TeamGrid } from "../components/TeamGrid"
import { galleryImages } from "../assets/gallery"

const teamMembers = [
	{
		name: "apl. Prof. Dr. Marcus Ventzke",
		role: "Geschäftsführung",
		image: marcus,
		alt: "apl. Prof. Dr. Marcus Ventzke",
		vitaUrl: "/marcus-ventzke-vita/",
		description: "Wissen, was Lernen braucht und wie man es entstehen lässt. Darin steckt sein Antrieb: Inhalte durchdringen, Zusammenhänge ordnen, Konzepte entwerfen, Didaktik vom Lernenden her denken, Fragen stellen, die unbequem sind. Marcus Ventzke ist Inhaltsmensch durch und durch – habilitierter Geschichtsdidaktiker und leidenschaftlicher Konzepter: erst der Inhalt, dann die Form. Doch er denkt nie nur fachlich. Bildung ist für ihn immer auch eine gesellschaftliche Frage. Es steht immer etwas Grundsätzliches auf seiner Agenda.",
	},
	{
		name: "Dr. Florian Sochatzy",
		role: "Geschäftsführung",
		image: flo,
		alt: "Dr. Florian Sochatzy",
		vitaUrl: "/florian-sochatzy-vita/",
		description: "Wissen, was man tut – und warum man es tut. Darin steckt sein Antrieb, dem er mit spürbarer Intensität nachgeht: zuhören, lesen, Konzepte entwickeln, Strategien hinterfragen, eigene Erfahrungen einbringen, Medien produzieren und Menschen für Ideen begeistern. Er bewegt sich gern dort, wo Inhalt, Technik und Gestaltung zusammenkommen – und sorgt dafür, dass aus einer guten Idee am Ende ein Produkt wird, das funktioniert und überzeugt. Theorie und Praxis sind für ihn keine Gegensätze, sondern zwei Seiten derselben Arbeit. Was ihn auszeichnet, ist die Neugier, mit der er an Neues herangeht, und die Konsequenz, mit der er es zu Ende bringt. Auf seiner Agenda steht deshalb immer etwas Spannendes.",
	},
	{
		name: "Veronika Obermeier",
		role: "Inhalt & Konzepte",
		image: obi,
		alt: "Veronika Obermeier",
		description: "Unser Team aus Didaktikern deckt breite Wissensfelder ab und kennt sich mit dem aktuellen Stand der Bildungs- und Wissenschaftssysteme aus. Nahe an didaktischen Vielfalten bleiben wir durch den intensiven Austausch mit Schulen, Museen und Kultureinrichtungen. Wir achten dabei immer darauf, unsere Inhalte passgenau der Zielgruppe anzupassen.",
	},
	{
		name: "Kevin Michelfelder",
		role: "Entwicklung & IT",
		image: kevin,
		alt: "Kevin Michelfelder",
		description: "Bei technischen Lösungen sind unsere IT-Experten immer zur Stelle. Sie erschaffen aus bloßen Vorstellungen konkrete Anwendungen. Dabei scheuen sie sich nie, neue und innovative Wege zu beschreiten. Diese digitalen Kompetenzen lassen wir stets zielführend in unsere Projekte einfließen.",
	},
	{
		name: "Fabian Hell",
		role: "Video & Audio",
		image: fabi,
		alt: "Fabian Hell",
		description: "Die Produktion hochwertiger Lern- und Erklärvideos ist in der heutigen Zeit unabdingbar. Durch die Unterstützung unserer Video- und Audio-Abteilung können wir u.a. maßgeschneidertes Unterrichtsmaterial erstellen. Hierfür betreiben wir ein hauseigenes Greenscreenstudio und ein Tonstudio, in dem wir Podcasts, Sprechertexte und vieles mehr aufnehmen. Vom Script über die Aufnahme bis zur Nachbearbeitung entsteht so alles aus einer Hand.",
	},
	{
		name: "Carla Figge",
		role: "Grafik",
		image: carla,
		alt: "Carla Figge",
		description: "Durch unsere Grafikabteilung werden Ideen und Konzepte ästhetische Wirklichkeit. Mit hochwertigen Grafiken gewinnen unsere Produktionen an Leben, egal ob Ausstellungen, digitale Bildungsprojekte, App-Oberflächen oder Raumgestaltungen.",
	},
	{
		name: "Paula Poggemann",
		role: "Motion",
		image: paula,
		alt: "Paula Poggemann",
		description: "Bewegung erzählt Geschichten. Mit Animation und Motiondesign setzen wir Inhalte lebendig in Szene, vom erklärenden Videoclip bis zu dynamischen Elementen für digitale Anwendungen. Dabei gilt: Möglich ist alles, was inhaltlich sinnvoll ist und die Botschaft stärkt.",
	},
	{
		name: "Chris Liebscher",
		role: "Instruktionsdesign",
		image: chris,
		alt: "Chris Liebscher",
		description: "Didaktische Passgenauigkeit, intuitive Benutzbarkeit und konkrete Anwendung: Wir reflektieren unsere Materialien und fügen sie so in unsere Inhalts-Architektur, dass sie, meist eingebettet in einen lebenspraktischen Kontext, die Kompetenzentwicklung der Lernenden optimal unterstützen.",
	},
	{
		name: "Felix Bornheim",
		role: "Projektmanagement",
		image: felix,
		alt: "Felix Bornheim",
		description: "Die reibungslose Organisation innovativer Bildungsprojekte ist in der modernen Lernwelt unersetzbar. Dank der Erfahrung im Bereich Projektleitung und Koordination vernetzen wir Expertinnen und Experten, damit digitale Inhalte effizient umgesetzt werden. Von der ersten Idee bis zur Finalisierung stellen wir sicher, dass jedes Vorhaben erfolgreich realisiert wird.",
	},
	{
		name: "Asti",
		role: "Feel-Good-Management",
		image: asti,
		alt: "Asti",
		description: "Er ist sehr flauschig.",
		imageScale: 0.7,
	},
];

const aboutUsHeaderSections = [
	{
		title: "Unsere Kompetenz",
		subTitle: "ganzheitliche Projekte",
		text: "Wir kennen die Bedürfnisse öffentlicher und privater Auftraggeber – seit Jahren arbeiten wir erfolgreich mit Kultusministerien, Landesämtern, Bundesbehörden, Stiftungen und Vereinen zusammen. Unsere Projekte werden in diesen Kooperationen grundsätzlich termingerecht und im vereinbarten Kostenrahmen fertiggestellt.",
	},
	{
		title: "Unsere Leistungen",
		subTitle: "alles aus einer Hand",
		text: "Die möglichen Leistungen bei der erfolgreichen Entwicklung eines Projekts umfassen die Bereiche Strategie, Konzeption, Projektorganisation, Content-Produktion, Technologie, Implementierung, langfristige Betreuung und öffentliche Kommunikation. Wir finden praktikable Lösungen im Bildungs- und Kulturbereich – sei es Lehrkräftemangel, Inklusion, Medienbildung, Diversität, Bildung für nachhaltige Entwicklung, Kompetenzorientierung, künstliche Intelligenz oder virtuellen Realitäten.",
	},
	{
		title: "Unsere Lösungen",
		subTitle: "als Antwort auf akute Krisen",
		text: "Corona, Ukraine, Lehrermangel – drei Krisen aus der letzten Zeit, auf die wir schnell und kreativ mit spezifischen digitalen Lösungen antworten konnten. So entstanden z. B. Lerneinheiten für den Distanzunterricht, digitale Alphabetisierungs-Materialien (DaZ) und Selbstlern-Module mit integrierten Videolehrkräften.",
	},
	{
		title: "Unsere Geschichte",
		subTitle: "über 10 Jahre Engagement für digitale Bildung",
		text: "Das Team der Digitalen Lernwelten prägt seit über zehn Jahren eine von Didaktik und Inhalt motivierte Digitalisierung der Bildung aktiv mit. Unter anderem stehen die Auszeichnungen ‘Schulbuch des Jahres’ und ‘Digital Publishing Award’ für diesen Weg und den damit verbundenen Erfolg. Wir beteiligen uns aktiv und kritisch am aktuellen Bildungsdiskurs.",
	},
];
---


<Layout
	title="Digitale Lernwelten"
	bodyClass="index"
	description="Digitale Lernwelten konzipiert und produziert digitale Bildungsmedien, E-Learning-Angebote und multimediale Lösungen für Bildung, Wissenschaft und Kultur."
>
	<HeaderImage images={headerImages} gradient>
		<HeaderText client:load/>
		<Logo client:load />
	</HeaderImage>
	<MobileHeaderText client:load/>
	<AboutUsHeaderCard sections={aboutUsHeaderSections} />
	<TeamGrid members={teamMembers} client:visible />
	<AboutUsGalleryCard 
		client:only="react"
		images={galleryImages} 
	/>

	<!-- <HeaderTextParagraph
		client:load
		header="Unsere Kernkompetenz"
		subheader="Ganzheitliche digitale Bildungsprojekte"
		text=`Wir kennen die Bedürfnisse öffentlicher und privater Auftraggeber – seit Jahren arbeiten wir erfolgreich mit Kultusministerien, Landesämtern, Bundesbehörden, Stiftungen und Vereinen zusammen. Unsere Projekte werden in diesen Kooperationen grundsätzlich termingerecht und im vereinbarten Kostenrahmen fertiggestellt.
		Die dafür notwendigen Kompetenzen sind ein effizient strukturiertes Projektmanagement, zielgenaue Kommunikation und transdisziplinäre Fachkenntnis.`
	/>
	<HeaderTextParagraph
		client:load
		header="Unsere Leistungen"
		subheader="alles aus einer Hand"
		text=`Die möglichen Leistungen bei der erfolgreichen Entwicklung eines Projekts umfassen die Bereiche Strategie, Konzeption, Projektorganisation, Inhalts- und Medienproduktion, Technologieentwicklung, Implementierung, langfristige Betreuung und öffentliche Kommunikation.
		Wir finden praktikable Lösungen für die aktuellen und langfristigen Herausforderungen im Bildungs- und Kulturbereich – sei es Lehrkräftemangel, Inklusion, Medienbildung, Diversität, Bildung für nachhaltige Entwicklung, Kompetenzorientierung oder der Umgang mit künstlicher Intelligenz und virtuellen Realitäten.`
	/>
	<HeaderTextParagraph
		client:load
		header="Unsere digitalen Lösungen"
		subheader="als Antwort auf akute Krisen"
		text=`Corona, Ukraine, Lehrermangel – drei Krisen aus der letzten Zeit, auf die wir schnell und kreativ mit spezifischen digitalen Lösungen antworten konnten. So entstanden z.&nbsp;B. Lerneinheiten für den Distanzunterricht, digitale Alphabetisierungs-Materialien (DaZ) und Selbstlern-Module mit integrierten Videolehrkräften.`
	/>
	<HeaderTextParagraph
		client:load
		header="Unsere Geschichte"
		subheader="über 10 Jahre Engagement für digitale Bildung"
		text=`Das Team der Digitalen Lernwelten prägt seit über zehn Jahren eine von Didaktik und Inhalt motivierte Digitalisierung der Bildung aktiv mit. Unter anderem stehen die Auszeichnungen ‘Schulbuch des Jahres’ und ‘Digital Publishing Award’ für diesen Weg und den damit verbundenen Erfolg. Wir beteiligen uns aktiv und kritisch am aktuellen Bildungsdiskurs. Dafür nutzen wir Formate wie den Podcast ‘EduCouch’ oder die gestaltende Teilnahme an Tagungen und Konferenzen.`
	/>
	<TeamSlider
		client:idle
		headline="Kompetenzen"
		slides={
			[
				{
					name: "Geschäftsführung & Strategie",
					portraitLeftName: "Dr. Florian Sochatzy",
					portraitRightName: "Prof. Dr. Marcus Ventzke",
					portraitWide: true,
					portrait: portraitFloMarcus,
					text: `Wissen, was man tut und wie man es tut. Darin stecken die Voraussetzungen, denen wir mit Intensität nachgehen. Immer und überall. Lesen, Konzepte entwickeln, Strategien reflektieren, eigene Erfahrungen einbringen. So kann man Menschen von Ideen begeistern - und dafür sorgen, dass immer etwas Spannendes auf die Agenda rückt. Langeweile ist nicht.`,
				},{
					name: "Grafik & Motion",
					portraitName: "Piera Jelinek",
					portrait: portraitPiera,
					text: `Durch unsere Grafikabteilung werden Ideen und Konzepte ästhetische Wirklichkeit. Mit hochwertigen Grafiken gewinnen unsere Produktionen an Leben, egal ob Ausstellungen, digitale Bildungsprojekte, App-Oberflächen oder Raumgestaltungen. Auch bei Animation und Motiondesign ist alles möglich, was inhaltlich sinnvoll ist.`,
				},{
					name: "Entwicklung & IT",
					portraitName: "Benjamin Schulenburg",
					portrait: portraitBen,
					text: `Bei technischen Lösungen sind unsere IT-Experten immer zur Stelle. Sie erschaffen aus bloßen Vorstellungen konkrete Anwendungen. Dabei scheuen sie sich nie, neue und innovative Wege zu beschreiten. Diese digitalen Kompetenzen lassen wir stets zielführend in unsere Projekte einfließen.`,
				},{
					name: "Video & Audio",
					portraitName: "Fabian Hell",
					portrait: portraitFabi,
					text: `Die Produktion hochwertiger Lern- und Erklärvideos ist in der heutigen Zeit unabdingbar. Durch die Unterstützung unserer Video- und Audio-Abteilung können wir u.a. maßgeschneidertes Unterrichtsmaterial erstellen. Hierfür betreiben wir ein hauseigenes Greenscreenstudio und ein Tonstudio, in dem wir Podcasts, Sprechertexte und vieles mehr aufnehmen. Vom Script über die Aufnahme bis zur Nachbearbeitung entsteht so alles aus einer Hand.`,
				},{
					name: "Inhalt & Konzepte",
					portraitName: "Veronika Obermeier",
					portrait: portraitObi,
					text: `Unser Team aus Didaktikern deckt breite Wissensfelder ab und kennt sich mit dem aktuellen Stand der Bildungs- und Wissenschaftssysteme aus. Nahe an didaktischen Vielfalten bleiben wir durch den intensiven Austausch mit Schulen, Museen und Kultureinrichtungen. Wir achten dabei immer darauf, unsere Inhalte passgenau der Zielgruppe anzupassen.`,
				}
			]
		}
	/> -->
</Layout>

<style>
	h3 a {
		color: inherit;
		text-decoration: none;
		border-bottom: 1px solid currentColor;
		transition: opacity 0.2s;
	}

	h3 a:hover {
		opacity: 0.7;
	}
</style>
